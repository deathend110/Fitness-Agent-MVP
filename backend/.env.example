DATABASE_URL=sqlite+aiosqlite:///./data/repmind.db
DATA_DIR=./data
UPLOADS_DIR=./data/uploads
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
MAX_UPLOAD_MB=15
ALLOWED_UPLOAD_EXTENSIONS=[".png",".jpg",".jpeg",".webp",".xlsx",".xlsm",".docx",".md",".txt"]
CORS_ORIGINS=["http://localhost:5173"]
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEFAULT_MODEL=deepseek-v4-flash
MODEL_ALLOWLIST=["deepseek-v4-flash","deepseek-v4-pro"]
DEFAULT_THINKING_ENABLED=false
DEFAULT_THINKING_BUDGET=auto
LLM_TIMEOUT_SECONDS=30
# 兼容旧变量名：如果仍使用 DEEPSEEK_TIMEOUT_SECONDS，也会回落到同一超时配置。
MODEL_PROVIDER_CONFIG_PATH=./config/model_providers.json
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=127.0.0.1,localhost
