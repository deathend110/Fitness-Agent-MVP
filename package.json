{
  "name": "repmind-mvp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "uv run python -m backend.run_dev_server",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "stop:all": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-repmind.ps1",
    "test": "node --test \"tests/*.test.js\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
